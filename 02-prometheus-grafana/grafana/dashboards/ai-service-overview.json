{
  "title": "AI Service Overview (Day 23)",
  "uid": "day23-ai-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "templating": {"list": [
    {"name": "model", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"},
"query": "label_values(inference_requests_total, model)",
      "refresh": 2, "includeAll": true, "multi": false, "current": {"value": "llama3-mock", "text": "llama3-mock"}}
  ]},
  "panels": [
    {
      "type": "timeseries", "title": "Request Rate (RPS) by status",
      "id": 1, "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (status) (rate(inference_requests_total{model=\"$model\"}[1m]))",
        "legendFormat": "{{status}}", "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries", "title": "Latency P50 / P95 / P99",
      "id": 2, "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(inference_latency_seconds_bucket{model=\"$model\"}[5m])))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(inference_latency_seconds_bucket{model=\"$model\"}[5m])))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(inference_latency_seconds_bucket{model=\"$model\"}[5m])))", "legendFormat": "P99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "stat", "title": "Error Rate (last 5m)",
      "id": 3, "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "100 * (sum(rate(inference_requests_total{status=\"error\"}[5m])) / sum(rate(inference_requests_total[5m])))",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "percent",
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 1},
          {"color": "red", "value": 5}
        ]}
      }}
    },
    {
      "type": "gauge", "title": "GPU Utilization",
      "id": 4, "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gpu_utilization_percent", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries", "title": "Token Throughput (in/out per sec)",
      "id": 5, "gridPos": {"x": 12, "y": 8, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (direction) (rate(inference_tokens_total{model=\"$model\"}[1m]))",
        "legendFormat": "{{direction}}", "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "stat", "title": "In-Flight Requests",
      "id": 6, "gridPos": {"x": 18, "y": 8, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "inference_active_gauge", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
